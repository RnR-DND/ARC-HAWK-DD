# ARC-Hawk Environment Variables — copy to .env and fill in real values
# Never commit .env to source control.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=arc_platform
DB_SSLMODE=disable
# Fallback SSL mode used by go-scanner when DB_SSLMODE is not set
DB_SSLMODE_DEFAULT=disable

# Full DSN alternative (overrides individual DB_* vars if set)
# DATABASE_URL=postgres://postgres:password@localhost:5432/arc_platform?sslmode=disable

# ── Postgres (Docker Compose) ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=arc_platform

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
# Set to "release" in production (disables debug output)
GIN_MODE=debug
APP_VERSION=3.0.1

# ── Authentication ──────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
# Set to "false" ONLY for local development — must be "true" in production
AUTH_REQUIRED=false

# ── Encryption ──────────────────────────────────────────────────────────────
# REQUIRED: Exactly 32 characters. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here_

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_strong_password

# ── Presidio ML Integration ──────────────────────────────────────────────────
PRESIDIO_ENABLED=true
PRESIDIO_ADDR=http://presidio-analyzer:3000
PRESIDIO_URL=http://presidio-analyzer:3000

# ── Temporal Workflow Engine ─────────────────────────────────────────────────
TEMPORAL_ENABLED=false
TEMPORAL_HOST_PORT=temporal:7233
TEMPORAL_DB_PORT=5432
TEMPORAL_TLS_ENABLED=false

# ── Scanner ─────────────────────────────────────────────────────────────────
SCANNER_URL=http://go-scanner:8001
BACKEND_URL=http://backend:8080
# Shared secret between backend and go-scanner. Generate with: openssl rand -hex 32
SCANNER_SERVICE_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
SCANNER_AUTH_REQUIRED=true
# Wall-clock cap on any single scan (seconds)
SCAN_TIMEOUT_SECONDS=1800

# ── Vault (HashiCorp) ────────────────────────────────────────────────────────
VAULT_ENABLED=false
VAULT_ADDR=http://vault:8200
# Dev mode token — rotate before production
VAULT_DEV_ROOT_TOKEN=CHANGE_ME_dev_root_token
VAULT_TOKEN=CHANGE_ME_dev_root_token
VAULT_SECRET_MOUNT=secret
# AppRole auth (production alternative to token)
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# ── Remediation ──────────────────────────────────────────────────────────────
# Keep false until verified connector write-paths are tested
REMEDIATION_ENABLED=false

# ── PII Storage mode: full | mask | none ─────────────────────────────────────
PII_STORE_MODE=full

# ── Classification tuning ────────────────────────────────────────────────────
CLASSIFIER_VERSION=1
CLASSIFICATION_WEIGHT_RULES=0.40
CLASSIFICATION_WEIGHT_CONTEXT=0.30
CLASSIFICATION_WEIGHT_ENTROPY=0.10
CLASSIFICATION_THRESHOLD=0.60
LINEAGE_CONFIDENCE_THRESHOLD=0.70

# ── Tenant limits ────────────────────────────────────────────────────────────
TENANT_MAX_CONCURRENT_SCANS=5

# ── Supermemory.ai (optional — cross-session memory) ─────────────────────────
SUPERMEMORY_ENABLED=false
SUPERMEMORY_API_KEY=CHANGE_ME_get_from_app_supermemory_ai
SUPERMEMORY_API_URL=https://api.supermemory.ai

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACE_SAMPLE_RATE=0.1
# OTEL_INSECURE=true

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password
