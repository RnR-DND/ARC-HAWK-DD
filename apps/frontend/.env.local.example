# ARC-HAWK-DD Frontend — Local Development Environment
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Backend API base URL (without trailing slash)
# - Docker Compose: set automatically to http://backend:8080/api/v1
# - Local dev (go run ./cmd/server): http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: override the default Next.js port (default 3000)
# PORT=3000
