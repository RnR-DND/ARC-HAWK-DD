# ARC-Hawk Backend Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=arc_platform
DB_SSLMODE=disable

# ── Postgres (Docker Compose) ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=arc_platform

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
# Set to "release" in production (disables debug output)
GIN_MODE=debug

# ── Authentication ──────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Set to "false" ONLY for local development — must be "true" in production
AUTH_REQUIRED=true

# ── Encryption ──────────────────────────────────────────────────────────────
# REQUIRED: Exactly 32 characters. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here_

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_strong_password

# ── Presidio ML Integration (optional) ──────────────────────────────────────
PRESIDIO_ENABLED=true
PRESIDIO_ADDR=http://localhost:3001

# ── Temporal Workflow Engine (optional) ─────────────────────────────────────
TEMPORAL_ENABLED=false
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_DB_PORT=5432

# ── Vault (optional — credential lifecycle management) ──────────────────────
# Set to "true" to store connection credentials in HashiCorp Vault KV v2.
# When disabled, credentials are encrypted with AES-256-GCM in PostgreSQL.
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
# Dev mode token — use AppRole or K8s auth in production
VAULT_DEV_ROOT_TOKEN=arc-hawk-dev-token
VAULT_TOKEN=arc-hawk-dev-token
VAULT_SECRET_MOUNT=secret

# ── Scanner ─────────────────────────────────────────────────────────────────
SCANNER_URL=http://localhost:8001
BACKEND_URL=http://localhost:8080

# ── Grafana ─────────────────────────────────────────────────────────────────
# REQUIRED if running Grafana via docker-compose
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Classification tuning (optional) ────────────────────────────────────────
CLASSIFICATION_WEIGHT_RULES=0.40
CLASSIFICATION_WEIGHT_CONTEXT=0.30
CLASSIFICATION_WEIGHT_ENTROPY=0.10
CLASSIFICATION_THRESHOLD=0.60

# ── PII Storage mode: full | mask | none ────────────────────────────────────
PII_STORE_MODE=full

# Supermemory.ai — memory & hybrid-search layer
# Free tier: 1M tokens/month + 10K search queries/month
# Get your key at https://app.supermemory.ai
# When SUPERMEMORY_ENABLED!=true or key missing, all memory calls no-op safely.
SUPERMEMORY_ENABLED=false
SUPERMEMORY_API_KEY=
SUPERMEMORY_API_URL=https://api.supermemory.ai
